<?xml version="1.0" encoding="UTF-8"?>
<opml version="2.0">
  <head>
    <title>Nested folders fixture</title>
  </head>
  <body>
    <outline text="Tech" title="Tech">
      <outline text="AI" title="AI">
        <outline
          text="AI Feed"
          title="AI Feed"
          type="rss"
          xmlUrl="https://example.com/ai.xml"
          category="Tech/AI"
        />
      </outline>
      <outline
        text="Tech News"
        title="Tech News"
        type="rss"
        xmlUrl="https://example.com/news.xml"
        category="Tech"
      />
    </outline>
  </body>
</opml>
